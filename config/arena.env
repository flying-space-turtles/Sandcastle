# Canonical Sandcastle arena configuration.
#
# scripts/setup.sh validates this file and generates docker-compose.yml plus
# per-team service Compose files from it. Keep values as simple KEY=VALUE pairs.

ARENA_TEAM_COUNT=2

ARENA_CTF_SUBNET=10.10.0.0/16
ARENA_CTF_GATEWAY=10.10.0.1
ARENA_SSH_BASE_PORT=2200
ARENA_SSH_BIND_HOST=127.0.0.1
ARENA_SERVICE_PORT=8080

ARENA_TEAM_USERNAME_PATTERN=team{team}
ARENA_TEAM_PASSWORD_PATTERN=team{team}pass
# Local development submission credentials. Replace this pattern before a real event.
ARENA_TEAM_TOKEN_PATTERN=sandcastle-team{team}-submission-token-change-me
ARENA_SERVICE_TEMPLATE=services/example-vuln

ARENA_FIREWALL_WS_PORT=6789
ARENA_FIREWALL_PROXY_PORT=15000
ARENA_FIREWALL_PROBE_PORT=18080
ARENA_FIREWALL_SMOKE_TIMEOUT_SECONDS=15
ARENA_FIREWALL_EVENT_QUEUE_SIZE=2048
ARENA_FIREWALL_CAPTURE_RCVBUF_BYTES=4194304
ARENA_FIREWALL_RECENT_ICMP_LIMIT=4096

ARENA_BOT_API_HOST=127.0.0.1
ARENA_BOT_API_PORT=7878
ARENA_BOT_LOOP_SECONDS=60
ARENA_VISUALIZER_BIND_HOST=127.0.0.1
ARENA_VISUALIZER_PORT=4173
ARENA_STARTUP_TIMEOUT_SECONDS=120

# AI agent planning. Provider credentials remain in the local .env file.
ARENA_AGENT_PROVIDER=fake
ARENA_AGENT_MODEL=gpt-5.4-mini
ARENA_AGENT_FALLBACK_PROVIDER=fake
ARENA_AGENT_MAX_CALLS_PER_ROUND=2
ARENA_AGENT_MAX_CALLS_PER_MATCH=30
ARENA_AGENT_MAX_INPUT_CHARS=20000
ARENA_AGENT_MAX_OUTPUT_TOKENS=500
ARENA_AGENT_MAX_COST_USD_PER_CALL=0.25
ARENA_AGENT_MAX_COST_USD_PER_MATCH=5.00
ARENA_AGENT_MAX_COST_USD_PER_DAY=25.00
ARENA_AGENT_TIMEOUT_SECONDS=15
ARENA_AGENT_MAX_RETRIES=1
ARENA_OPENAI_INPUT_COST_PER_MTOK=0.75
ARENA_OPENAI_OUTPUT_COST_PER_MTOK=4.50
ARENA_CHALLENGE_MAX_ATTEMPTS=3
ARENA_CHALLENGE_MAX_COST_USD=3.00

# Authoritative gameserver round and checker scheduling settings.
ARENA_ROUND_DURATION_SECONDS=120
ARENA_FLAG_EXPIRY_ROUNDS=5
ARENA_CHECKER_MAX_CONCURRENCY=8
ARENA_GAMESERVER_PORT=8000
# Local operator credential for match controls. Replace before a real event.
ARENA_OPERATOR_TOKEN=sandcastle-local-operator-token-change-me
ARENA_SUBMISSION_RATE_LIMIT=60
ARENA_SUBMISSION_RATE_WINDOW_SECONDS=60

# Immutable per-match scoring weights copied into the gameserver database.
ARENA_SCORE_ATTACK_POINTS=10
ARENA_SCORE_DEFENSE_POINTS=2
ARENA_SCORE_SLA_POINTS=1

# Local trusted-mode master key used to derive distinct credentials for every
# team/service checker scope. Override this before running a real event.
ARENA_CHECKER_SECRET=sandcastle-local-checker-secret-change-me

# Isolation mode controls how team containers access Docker.
#   trusted   — host Docker socket mounted directly (default, trusted-local only)
#   isolated  — per-team filter proxy; teams cannot reach other teams' containers
#   dind      — per-team Docker-in-Docker daemon, intended for production tests
# See docs/isolation.md and docs/THREAT_MODEL.md before changing this value.
ARENA_ISOLATION_MODE=trusted
ARENA_DIND_DNS_SERVERS=1.1.1.1,8.8.8.8

# Resource limits — team containers (untrusted; prevent one team exhausting the host)
# Memory values use Docker shorthand: b, k, m, g (case-insensitive).
# CPU values are decimal vCPU fractions. PID values are integers.
ARENA_TEAM_VULN_MEM_LIMIT=512m
ARENA_TEAM_VULN_CPU_LIMIT=0.50
ARENA_TEAM_VULN_PIDS_LIMIT=200
ARENA_TEAM_SSH_MEM_LIMIT=128m
ARENA_TEAM_SSH_CPU_LIMIT=0.25
ARENA_TEAM_SSH_PIDS_LIMIT=100
ARENA_TEAM_APP_MEM_LIMIT=256m
ARENA_TEAM_APP_CPU_LIMIT=0.50
ARENA_TEAM_APP_PIDS_LIMIT=100
# Maximum container restart attempts before Docker stops retrying.
ARENA_TEAM_MAX_RESTARTS=5

# Resource limits — control plane (reserved; must survive team container abusers)
ARENA_GAMESERVER_MEM_LIMIT=512m
ARENA_GAMESERVER_CPU_LIMIT=1.00
ARENA_BOT_MEM_LIMIT=256m
ARENA_BOT_CPU_LIMIT=0.50
ARENA_VISUALIZER_MEM_LIMIT=128m
ARENA_VISUALIZER_CPU_LIMIT=0.25
ARENA_FIREWALL_MEM_LIMIT=128m
ARENA_FIREWALL_CPU_LIMIT=0.50

# Log rotation — prevent disk exhaustion from unbounded container stdout/stderr.
ARENA_LOG_MAX_SIZE=50m
ARENA_LOG_MAX_FILES=3
