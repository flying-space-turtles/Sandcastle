# Copy this file to .env (./scripts/start.sh will do it for you on first run)
# and edit values to taste. docker compose and the helper scripts read .env
# automatically, so VULN_IMAGE no longer needs to be exported in your shell.

# Vulnerable application image. The default is the bundled template service
# at services/example-vuln; ./scripts/start.sh builds it for you when this
# value is unchanged. Set it to a different tag to plug in your own image.
VULN_IMAGE=sandcastle/example-vuln

# Vulnerable app port (default: 8080)
# VULN_PORT=8080

# CPU limit per team container (default: 2)
# TEAM_CPU_LIMIT=2

# Memory limit per team container (default: 2g)
# TEAM_MEM_LIMIT=2g
